rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Admin Check
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if true; // Allows the apps to read names/roles
      allow write: if request.auth != null && request.auth.uid == userId; // Users can edit themselves
      allow write: if isAdmin(); // Super Admins can edit anyone
    }

    // DYNAMIC RESTAURANT ROUTING
    match /restaurants/{restaurantId} {
      allow read: if true; // Customers can view all restaurants
      
      // THE MAGIC FIX: A restaurant can only edit data if the document ID matches their Login UID!
      allow write: if isAdmin() || request.auth.uid == restaurantId;

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isAdmin() || request.auth.uid == restaurantId;
      }

      match /menu/{menuId} {
        allow read: if true;
        allow write: if isAdmin() || request.auth.uid == restaurantId;
      }
    }

    match /orders/{orderId} {
      allow create: if request.auth != null; // Any logged-in user can place an order
      allow read, update: if request.auth != null; 
    }
  }
}
